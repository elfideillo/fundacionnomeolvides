---
const aliados = [
  { nombre: 'SernamEG', placeholder: true },
  { nombre: 'Municipalidad', placeholder: true },
  { nombre: 'ONU Mujeres', placeholder: true },
  { nombre: 'UNICEF', placeholder: true },
  { nombre: 'Red de Apoyo', placeholder: true },
];
---

<section class="py-16 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12" data-aos="fade-up">
      <span class="inline-block px-4 py-2 bg-[#7C5CBF]/10 text-[#7C5CBF] rounded-full text-sm font-medium mb-4">
        Nuestros Aliados
      </span>
      <h2 class="font-heading text-2xl sm:text-3xl font-bold text-[#1F2937]">
        Trabajamos junto a organizaciones comprometidas
      </h2>
    </div>

    <div class="flex flex-wrap justify-center items-center gap-8 lg:gap-16" data-aos="fade-up" data-aos-delay="100">
      {aliados.map((aliado) => (
        <div class="grayscale hover:grayscale-0 opacity-60 hover:opacity-100 transition-all duration-300">
          <div class="w-32 h-16 bg-gray-100 rounded-lg flex items-center justify-center">
            <span class="text-gray-400 text-sm font-medium">{aliado.nombre}</span>
          </div>
        </div>
      ))}
    </div>

    <p class="text-center text-[#9CA3AF] text-sm mt-8">
      * Espacio para logos de organizaciones aliadas
    </p>
  </div>
</section>
