---
const servicios = [
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
    </svg>`,
    titulo: 'Acompañamiento emocional y psicosocial',
    descripcion: 'Generamos espacios seguros de escucha, contención y orientación, donde cada mujer puede expresar su historia sin juicios ni presiones.',
    bgColor: 'bg-[#7C5CBF]/10',
    textColor: 'text-[#7C5CBF]',
    hoverBg: 'group-hover:bg-[#7C5CBF]',
  },
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
    </svg>`,
    titulo: 'Orientación y apoyo en el acceso a derechos',
    descripcion: 'Entregamos información clara y comprensible para enfrentar procesos legales, institucionales o administrativos, fortaleciendo la toma de decisiones informadas.',
    bgColor: 'bg-[#E8839B]/10',
    textColor: 'text-[#E8839B]',
    hoverBg: 'group-hover:bg-[#E8839B]',
  },
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
    </svg>`,
    titulo: 'Redes de apoyo y comunidad',
    descripcion: 'Creemos en la fuerza del acompañamiento colectivo, la sororidad y la construcción de redes que sostienen y cuidan.',
    bgColor: 'bg-[#F4A261]/10',
    textColor: 'text-[#F4A261]',
    hoverBg: 'group-hover:bg-[#F4A261]',
  },
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/>
    </svg>`,
    titulo: 'Fortalecimiento de la autonomía',
    descripcion: 'Aportamos herramientas para recuperar la confianza, el proyecto de vida y la independencia personal y emocional.',
    bgColor: 'bg-[#7C5CBF]/10',
    textColor: 'text-[#7C5CBF]',
    hoverBg: 'group-hover:bg-[#7C5CBF]',
  },
];
---

<section id="que-hacemos" class="py-20 lg:py-28 bg-[#FFF5F0]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto mb-16" data-aos="fade-up">
      <span class="inline-block px-4 py-2 bg-[#E8839B]/10 text-[#E8839B] rounded-full text-sm font-medium mb-4">
        Qué Hacemos
      </span>

      <h2 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-bold text-[#1F2937] mb-6">
        Nuestras áreas de
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#7C5CBF] to-[#E8839B]">
          acompañamiento
        </span>
      </h2>

      <p class="text-[#6B7280] text-lg">
        Brindamos apoyo integral desde diferentes dimensiones para acompañar el proceso de cada mujer.
      </p>
    </div>

    <!-- Services grid -->
    <div class="grid md:grid-cols-2 gap-6 lg:gap-8 mb-16">
      {servicios.map((servicio, index) => (
        <div
          class="group bg-white rounded-3xl p-8 shadow-md hover:shadow-xl transition-all duration-300 hover:-translate-y-1"
          data-aos="fade-up"
          data-aos-delay={index * 100}
        >
          <div class={`w-16 h-16 ${servicio.bgColor} ${servicio.textColor} rounded-2xl flex items-center justify-center mb-6 transition-all duration-300 ${servicio.hoverBg} group-hover:text-white`}>
            <Fragment set:html={servicio.icon} />
          </div>

          <h3 class="font-heading text-xl lg:text-2xl font-semibold text-[#1F2937] mb-4">
            {servicio.titulo}
          </h3>

          <p class="text-[#6B7280] leading-relaxed">
            {servicio.descripcion}
          </p>
        </div>
      ))}
    </div>

    <!-- Image section -->
    <div class="grid lg:grid-cols-2 gap-12 items-center" data-aos="fade-up">
      <img
        src="/images/03.jpeg"
        alt="Ilustración de acompañamiento y apoyo"
        class="w-full max-w-md mx-auto rounded-full shadow-2xl object-cover aspect-square"
      />

      <div>
        <h3 class="font-heading text-2xl lg:text-3xl font-bold text-[#1F2937] mb-6">
          Un espacio seguro para tu proceso
        </h3>
        <p class="text-[#6B7280] text-lg leading-relaxed mb-6">
          Cada mujer tiene su propio ritmo y sus propias necesidades. En Fundación No Me Olvides respetamos esos tiempos y construimos junto a cada una el camino hacia su bienestar.
        </p>
        <a
          href="#contactanos"
          class="inline-flex items-center text-[#7C5CBF] font-semibold hover:text-[#5A3D9E] transition-colors group"
        >
          Solicita información
          <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
