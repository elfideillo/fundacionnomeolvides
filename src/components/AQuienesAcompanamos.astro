---
const situaciones = [
  'Violencia psicológica',
  'Violencia física',
  'Violencia sexual',
  'Violencia económica',
  'Violencia intrafamiliar o de pareja',
  'Situaciones de control, miedo o abuso',
  'Procesos de denuncia o búsqueda de reparación',
];

const valores = [
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
    </svg>`,
    titulo: 'El cuidado y la empatía',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
    </svg>`,
    titulo: 'La perspectiva de género',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
    </svg>`,
    titulo: 'El respeto por los tiempos y decisiones de cada mujer',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
    </svg>`,
    titulo: 'Sin juicios / Sin culpas',
  },
];
---

<section id="a-quienes-acompanamos" class="py-20 lg:py-28 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto mb-16" data-aos="fade-up">
      <span class="inline-block px-4 py-2 bg-[#F4A261]/10 text-[#F4A261] rounded-full text-sm font-medium mb-4">
        A Quiénes Acompañamos
      </span>

      <h2 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-bold text-[#1F2937] mb-6">
        Estamos aquí para
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#7C5CBF] to-[#F4A261]">
          acompañarte
        </span>
      </h2>

      <p class="text-[#6B7280] text-lg">
        Acompañamos a mujeres que han vivido o están viviendo diferentes situaciones de violencia.
      </p>
    </div>

    <!-- Situaciones grid -->
    <div class="flex flex-wrap justify-center gap-4 mb-12" data-aos="fade-up" data-aos-delay="100">
      {situaciones.map((situacion, index) => (
        <div
          class="group relative px-6 py-4 bg-gradient-to-r from-[#7C5CBF]/5 to-[#E8839B]/5 rounded-2xl border border-[#7C5CBF]/10 hover:border-[#7C5CBF]/30 hover:shadow-md transition-all duration-300"
          data-aos="zoom-in"
          data-aos-delay={index * 50}
        >
          <div class="flex items-center gap-3">
            <div class="w-2 h-2 bg-gradient-to-r from-[#7C5CBF] to-[#E8839B] rounded-full"></div>
            <span class="text-[#1F2937] font-medium">{situacion}</span>
          </div>
        </div>
      ))}
    </div>

    <!-- Highlighted message with image -->
    <div class="grid lg:grid-cols-2 gap-12 items-center max-w-6xl mx-auto mb-20" data-aos="fade-up">
      <img
        src="/images/04.jpeg"
        alt="Ilustración de mujer siendo escuchada y apoyada"
        class="w-full max-w-md mx-auto rounded-full shadow-2xl object-cover aspect-square order-2 lg:order-1"
      />
      <div class="bg-gradient-to-r from-[#7C5CBF]/10 via-[#E8839B]/10 to-[#F4A261]/10 rounded-3xl p-8 lg:p-12 order-1 lg:order-2">
        <svg class="w-12 h-12 text-[#7C5CBF] mx-auto mb-6" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
        </svg>
        <p class="font-heading text-2xl lg:text-3xl text-[#1F2937] font-semibold leading-relaxed text-center">
          "No importa en qué etapa estés. Tu historia importa y merece ser escuchada."
        </p>
      </div>
    </div>

    <!-- Nuestro Enfoque -->
    <div data-aos="fade-up">
      <div class="text-center mb-12">
        <h3 class="font-heading text-2xl lg:text-3xl font-bold text-[#1F2937] mb-4">
          Nuestro Enfoque
        </h3>
        <p class="text-[#6B7280] max-w-2xl mx-auto">
          Trabajamos guiadas por principios que ponen a la mujer en el centro.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {valores.map((valor, index) => (
          <div
            class="bg-[#FFF5F0] rounded-2xl p-6 text-center hover:shadow-lg transition-all duration-300 group"
            data-aos="fade-up"
            data-aos-delay={index * 100}
          >
            <div class="w-14 h-14 bg-gradient-to-br from-[#7C5CBF] to-[#E8839B] rounded-xl flex items-center justify-center text-white mx-auto mb-4 group-hover:scale-110 transition-transform duration-300">
              <Fragment set:html={valor.icon} />
            </div>
            <h4 class="font-heading text-lg font-semibold text-[#1F2937]">
              {valor.titulo}
            </h4>
          </div>
        ))}
      </div>

      <!-- Final message -->
      <div class="text-center mt-12">
        <p class="text-xl text-[#E8839B] font-heading font-semibold italic">
          "Porque la violencia nunca es tu responsabilidad."
        </p>
      </div>
    </div>
  </div>
</section>
