---
const principios = [
  {
    numero: '01',
    titulo: 'El cuidado y la empatía',
    descripcion: 'Brindamos un espacio seguro de contención emocional donde tu bienestar es la prioridad. Te escuchamos con el corazón, validando tus sentimientos y acompañándote en cada paso de tu proceso de sanación con calidez y una atención humana.',
    color: '#7C5CBF',
  },
  {
    numero: '02',
    titulo: 'La perspectiva de género',
    descripcion: 'Analizamos y abordamos la violencia entendiendo las raíces estructurales y las desigualdades que la sustentan. Nuestro enfoque reconoce tus vivencias específicas como mujer, trabajando juntas para desaprender mandatos y fortalecer tu autonomía.',
    color: '#E8839B',
  },
  {
    numero: '03',
    titulo: 'El respeto por los tiempos y decisiones de cada mujer',
    descripcion: 'Tú eres la dueña de tu camino. Respetamos tu ritmo individual sin presiones ni imposiciones; estamos aquí para informarte y apoyarte en las decisiones que tú consideres mejores para tu vida y tu seguridad, cuando te sientas lista.',
    color: '#F4A261',
  },
  {
    numero: '04',
    titulo: 'Sin juicios / Sin culpas',
    descripcion: 'Este es un entorno libre de críticas. Entendemos que la violencia es una situación compleja de la cual no eres responsable. Aquí transformamos la culpa en herramientas de habilitación, recordándote siempre que la violencia nunca es tu responsabilidad.',
    color: '#7C5CBF',
  },
];
---

<section id="nuestro-enfoque" class="py-20 lg:py-28 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto mb-16" data-aos="fade-up">
      <span class="inline-block px-4 py-2 bg-[#7C5CBF]/10 text-[#7C5CBF] rounded-full text-sm font-medium mb-4">
        Nuestro Enfoque
      </span>

      <h2 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-bold text-[#1F2937] mb-6">
        Cómo te
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#7C5CBF] to-[#E8839B]">
          acompañamos
        </span>
      </h2>

      <p class="text-[#6B7280] text-lg">
        Nuestro acompañamiento se basa en principios fundamentales que guían cada interacción.
      </p>
    </div>

    <!-- Principios grid -->
    <div class="grid md:grid-cols-2 gap-8 lg:gap-10">
      {principios.map((principio, index) => (
        <div
          class="relative bg-[#FFF5F0] rounded-3xl p-8 lg:p-10 hover:shadow-xl transition-all duration-300 hover:-translate-y-1"
          data-aos="fade-up"
          data-aos-delay={index * 100}
        >
          <!-- Numero decorativo -->
          <span
            class="absolute -top-4 -left-2 font-heading text-7xl font-bold opacity-10"
            style={`color: ${principio.color}`}
          >
            {principio.numero}
          </span>

          <div class="relative">
            <h3 class="font-heading text-xl lg:text-2xl font-semibold text-[#1F2937] mb-4">
              {principio.titulo}
            </h3>

            <p class="text-[#6B7280] leading-relaxed">
              {principio.descripcion}
            </p>
          </div>

          <!-- Linea decorativa inferior -->
          <div
            class="absolute bottom-0 left-8 right-8 h-1 rounded-full opacity-50"
            style={`background-color: ${principio.color}`}
          />
        </div>
      ))}
    </div>
  </div>
</section>
