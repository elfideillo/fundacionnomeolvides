---
const contactInfo = [
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
    </svg>`,
    label: 'Contacto General',
    value: 'contacto@fundacionnomeolvides.cl',
    isEmail: true,
  },
];

const emailsAreas = [
  { area: 'Presidencia', email: 'presidencia@fundacionnomeolvides.cl' },
  { area: 'Salud Mental', email: 'salud.mental@fundacionnomeolvides.cl' },
  { area: 'Bienestar', email: 'bienestar@fundacionnomeolvides.cl' },
  { area: 'Comunicaciones', email: 'comunicaciones@fundacionnomeolvides.cl' },
  { area: 'Secretaría', email: 'secretaria@fundacionnomeolvides.cl' },
];

const socialLinks = [
  {
    name: 'Instagram',
    icon: `<svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
      <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
    </svg>`,
    url: 'https://www.instagram.com/fundacionnomeolvides.cl',
  },
];
---

<section id="contactanos" class="py-20 lg:py-28 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto mb-16" data-aos="fade-up">
      <span class="inline-block px-4 py-2 bg-[#7C5CBF]/10 text-[#7C5CBF] rounded-full text-sm font-medium mb-4">
        Contáctanos
      </span>

      <h2 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-bold text-[#1F2937] mb-6">
        Estamos aquí para
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#7C5CBF] to-[#E8839B]">
          escucharte
        </span>
      </h2>

      <p class="text-[#6B7280] text-lg">
        Si necesitas acompañamiento, orientación o quieres colaborar con nuestro trabajo, escríbenos.
      </p>
    </div>

    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16">
      <!-- Contact Form -->
      <div class="bg-[#FFF5F0] rounded-3xl p-8 lg:p-10" data-aos="fade-right">
        <h3 class="font-heading text-2xl font-semibold text-[#1F2937] mb-6">
          Envíanos un mensaje
        </h3>

        <form id="contact-form" action="https://formspree.io/f/mnjgneql" method="POST" class="space-y-6">
          <div>
            <label for="nombre" class="block text-sm font-medium text-[#1F2937] mb-2">
              Nombre
            </label>
            <input
              type="text"
              id="nombre"
              name="nombre"
              required
              class="w-full px-4 py-3 bg-white rounded-xl border border-gray-200 focus:border-[#7C5CBF] focus:ring-2 focus:ring-[#7C5CBF]/20 outline-none transition-all"
              placeholder="Tu nombre"
            />
          </div>

          <div>
            <label for="email" class="block text-sm font-medium text-[#1F2937] mb-2">
              Correo electrónico
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full px-4 py-3 bg-white rounded-xl border border-gray-200 focus:border-[#7C5CBF] focus:ring-2 focus:ring-[#7C5CBF]/20 outline-none transition-all"
              placeholder="tu@correo.com"
            />
          </div>

          <div>
            <label for="mensaje" class="block text-sm font-medium text-[#1F2937] mb-2">
              Mensaje
            </label>
            <textarea
              id="mensaje"
              name="mensaje"
              rows="5"
              required
              class="w-full px-4 py-3 bg-white rounded-xl border border-gray-200 focus:border-[#7C5CBF] focus:ring-2 focus:ring-[#7C5CBF]/20 outline-none transition-all resize-none"
              placeholder="¿En qué podemos ayudarte?"
            ></textarea>
          </div>

          <!-- Honeypot anti-spam (oculto para usuarios, visible para bots) -->
          <input type="text" name="_gotcha" style="display:none" />

          <!-- reCAPTCHA -->
          <div class="g-recaptcha" data-sitekey="6LdrBYQsAAAAAMwEX6BfqoSIWjXRh77h6gGghIHD"></div>

          <button
            type="submit"
            class="w-full px-8 py-4 bg-gradient-to-r from-[#7C5CBF] to-[#5A3D9E] text-white font-semibold rounded-xl hover:shadow-xl transition-all duration-300 hover:scale-[1.02]"
          >
            Enviar mensaje
          </button>
        </form>

        <p class="text-[#9CA3AF] text-sm mt-4 text-center">
          Tu información está segura y será tratada con confidencialidad.
        </p>
      </div>

      <script is:inline>
        // Limpiar formulario al regresar a la página
        document.addEventListener('DOMContentLoaded', function() {
          const form = document.getElementById('contact-form');
          if (form) {
            form.reset();
            // Resetear reCAPTCHA si existe
            if (typeof grecaptcha !== 'undefined') {
              grecaptcha.reset();
            }
          }
        });
      </script>

      <!-- Contact Info -->
      <div data-aos="fade-left">
        <div class="bg-gradient-to-br from-[#7C5CBF] to-[#5A3D9E] rounded-3xl p-8 lg:p-10 text-white mb-8">
          <h3 class="font-heading text-2xl font-semibold mb-8">
            Información de contacto
          </h3>

          <div class="space-y-6">
            {contactInfo.map((info) => (
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-white/10 rounded-xl flex items-center justify-center flex-shrink-0">
                  <Fragment set:html={info.icon} />
                </div>
                <div>
                  <p class="text-white/70 text-sm mb-1">{info.label}</p>
                  {info.isEmail ? (
                    <a href={`mailto:${info.value}`} class="font-medium hover:text-[#E8839B] transition-colors">
                      {info.value}
                    </a>
                  ) : (
                    <p class="font-medium">{info.value}</p>
                  )}
                </div>
              </div>
            ))}
          </div>

          <!-- Correos por área -->
          <div class="mt-8 pt-6 border-t border-white/20">
            <p class="text-white/70 text-sm mb-4">Contacto por área</p>
            <div class="grid grid-cols-1 gap-2">
              {emailsAreas.map((item) => (
                <a
                  href={`mailto:${item.email}`}
                  class="flex items-center justify-between text-sm hover:bg-white/10 rounded-lg px-3 py-2 transition-colors group"
                >
                  <span class="text-white/80">{item.area}</span>
                  <span class="text-white/60 group-hover:text-[#E8839B] transition-colors text-xs">{item.email}</span>
                </a>
              ))}
            </div>
          </div>

          <!-- Social links -->
          <div class="mt-10 pt-8 border-t border-white/20">
            <p class="text-white/70 text-sm mb-4">Síguenos en redes sociales</p>
            <div class="flex gap-3">
              {socialLinks.map((social) => (
                <a
                  href={social.url}
                  class="w-12 h-12 bg-white/10 rounded-xl flex items-center justify-center hover:bg-white/20 transition-colors"
                  aria-label={social.name}
                >
                  <Fragment set:html={social.icon} />
                </a>
              ))}
            </div>
          </div>
        </div>

        <!-- Additional message -->
        <div class="bg-[#E8839B]/10 rounded-2xl p-6">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-[#E8839B]/20 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-[#E8839B]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
              </svg>
            </div>
            <div>
              <h4 class="font-heading font-semibold text-[#1F2937] mb-2">
                ¿Estás en una emergencia?
              </h4>
              <p class="text-[#6B7280] text-sm">
                Si estás en peligro inmediato, llama a Carabineros al <strong>133</strong> o al Fono de Orientación en Violencia <strong>1455</strong>.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
