---
---

<section id="aporte-voluntario" class="py-20 lg:py-28 bg-gradient-to-br from-[#7C5CBF]/5 via-[#FFF5F0] to-[#E8839B]/5">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <!-- Content -->
      <div data-aos="fade-right">
        <span class="inline-block px-4 py-2 bg-[#F4A261]/10 text-[#F4A261] rounded-full text-sm font-medium mb-4">
          Aporte Voluntario
        </span>

        <h2 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-bold text-[#1F2937] mb-6">
          Tu apoyo hace
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#7C5CBF] to-[#F4A261]">
            la diferencia
          </span>
        </h2>

        <p class="text-[#6B7280] text-lg leading-relaxed mb-8">
          Tu aporte nos permite seguir acompañando a mujeres que enfrentan situaciones de violencia y vulneración de derechos. Cada contribución, grande o pequeña, ayuda a sostener espacios de escucha, orientación y acompañamiento seguro.
        </p>

        <!-- Donation button -->
        <a
          href="#"
          class="inline-flex items-center px-8 py-4 bg-gradient-to-r from-[#F4A261] to-[#F8C99A] text-white font-semibold text-lg rounded-full hover:shadow-xl transition-all duration-300 hover:scale-105 mb-8"
        >
          <svg class="w-6 h-6 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
          </svg>
          Quiero aportar
        </a>

        <!-- Bank info placeholder -->
        <div class="bg-white rounded-2xl p-6 shadow-md">
          <h4 class="font-heading text-lg font-semibold text-[#1F2937] mb-4 flex items-center">
            <svg class="w-5 h-5 mr-2 text-[#7C5CBF]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
            </svg>
            Datos para transferencia
          </h4>

          <div class="space-y-2 text-[#6B7280]">
            <p><span class="font-medium text-[#1F2937]">Banco:</span> BancoEstado</p>
            <p><span class="font-medium text-[#1F2937]">Tipo de cuenta:</span> Cuenta Corriente</p>
            <p><span class="font-medium text-[#1F2937]">Número:</span> 23070410729</p>
            <p><span class="font-medium text-[#1F2937]">RUT:</span> 65.260.536-2</p>
            <p><span class="font-medium text-[#1F2937]">Titular:</span> Fundación No Me Olvides</p>
            <p><span class="font-medium text-[#1F2937]">Email:</span> voluntarios@fundacionnomeolvides.cl</p>
          </div>
        </div>
      </div>

      <!-- Image and quote -->
      <div data-aos="fade-left">
        <img
          src="/images/05.jpeg"
          alt="Ilustración de solidaridad y apoyo comunitario"
          class="w-full max-w-md mx-auto rounded-full shadow-2xl mb-8 object-cover aspect-square"
        />

        <!-- Inspiring quote -->
        <div class="bg-gradient-to-r from-[#7C5CBF] to-[#E8839B] rounded-2xl p-8 text-white">
          <svg class="w-10 h-10 mb-4 opacity-50" fill="currentColor" viewBox="0 0 24 24">
            <path d="M6 17h3l2-4V7H5v6h3zm8 0h3l2-4V7h-6v6h3z"/>
          </svg>
          <p class="font-heading text-xl lg:text-2xl leading-relaxed mb-4">
            Sanar es posible. Volver a empezar también.
          </p>
          <p class="text-white/80">
            En Fundación No Me Olvides, estamos contigo.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
