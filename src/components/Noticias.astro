---
const noticias = [
  {
    titulo: 'Inauguramos nuevo centro de acompañamiento',
    fecha: '15 de Febrero, 2025',
    descripcion: 'Abrimos un nuevo espacio seguro para el acompañamiento de mujeres en la región metropolitana.',
    categoria: 'Noticias',
  },
  {
    titulo: 'Taller de autocuidado y sanación',
    fecha: '10 de Febrero, 2025',
    descripcion: 'Realizamos un exitoso taller enfocado en herramientas de autocuidado para sobrevivientes.',
    categoria: 'Eventos',
  },
  {
    titulo: 'Alianza con organizaciones locales',
    fecha: '5 de Febrero, 2025',
    descripcion: 'Firmamos convenios de colaboración para ampliar nuestra red de apoyo.',
    categoria: 'Alianzas',
  },
];
---

<section class="py-20 lg:py-28 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16" data-aos="fade-up">
      <span class="inline-block px-4 py-2 bg-[#F4A261]/10 text-[#F4A261] rounded-full text-sm font-medium mb-4">
        Actualidad
      </span>
      <h2 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-bold text-[#1F2937]">
        Últimas <span class="text-[#F4A261]">noticias</span>
      </h2>
      <p class="mt-4 text-[#6B7280] text-lg max-w-2xl mx-auto">
        Mantente informada sobre nuestras actividades y eventos.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {noticias.map((noticia, index) => (
        <article
          class="bg-white rounded-3xl overflow-hidden shadow-lg hover:shadow-xl transition-all duration-300 hover:-translate-y-2"
          data-aos="fade-up"
          data-aos-delay={index * 100}
        >
          <!-- Image placeholder -->
          <div class="h-48 bg-gradient-to-br from-[#7C5CBF]/20 via-[#E8839B]/20 to-[#F4A261]/20 flex items-center justify-center">
            <svg class="w-16 h-16 text-[#7C5CBF]/30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/>
            </svg>
          </div>

          <div class="p-6">
            <div class="flex items-center gap-3 mb-3">
              <span class="px-3 py-1 bg-[#7C5CBF]/10 text-[#7C5CBF] rounded-full text-xs font-medium">
                {noticia.categoria}
              </span>
              <span class="text-[#9CA3AF] text-xs">{noticia.fecha}</span>
            </div>

            <h3 class="font-heading text-xl font-semibold text-[#1F2937] mb-3 line-clamp-2">
              {noticia.titulo}
            </h3>

            <p class="text-[#6B7280] text-sm leading-relaxed mb-4 line-clamp-3">
              {noticia.descripcion}
            </p>

            <a href="#" class="inline-flex items-center text-[#7C5CBF] font-medium text-sm hover:text-[#E8839B] transition-colors">
              Leer más
              <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        </article>
      ))}
    </div>

    <div class="text-center mt-12" data-aos="fade-up">
      <a
        href="#"
        class="inline-flex items-center px-6 py-3 border-2 border-[#7C5CBF] text-[#7C5CBF] rounded-full font-medium hover:bg-[#7C5CBF] hover:text-white transition-all duration-300"
      >
        Ver todas las noticias
        <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>
  </div>
</section>
